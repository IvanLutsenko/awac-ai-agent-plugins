#!/bin/bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
SCRIPT="$REPO_ROOT/plugins/plugin-cross-port/scripts/cross_port.py"
STATE="$REPO_ROOT/.plugin-cross-port.marketplace.yaml"

[ -f "$SCRIPT" ] || exit 0
[ -f "$STATE" ] || exit 0

CHANGED=$(git diff --cached --name-only --diff-filter=ACDMRTUXB)
[ -n "$CHANGED" ] || exit 0

SOURCE_MARKETPLACE=$(python3 - "$STATE" <<'PY'
import json
import sys
from pathlib import Path

try:
    state = json.loads(Path(sys.argv[1]).read_text(encoding="utf-8"))
except Exception:
    sys.exit(0)
print(state.get("source_marketplace", ""))
PY
)

if [ -n "$SOURCE_MARKETPLACE" ] && printf '%s\n' "$CHANGED" | grep -qx "$SOURCE_MARKETPLACE"; then
  python3 "$SCRIPT" --repo-root "$REPO_ROOT" marketplace sync --stage
  exit $?
fi

PLUGINS=$(
  printf '%s\n' "$CHANGED" |
    awk -F/ '$1 == "plugins" && NF >= 2 {print $2}' |
    sort -u |
    paste -sd, -
)

[ -n "$PLUGINS" ] || exit 0

python3 "$SCRIPT" --repo-root "$REPO_ROOT" \
  marketplace sync --changed-only "$PLUGINS" --stage
