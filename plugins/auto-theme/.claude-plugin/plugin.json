{
  "name": "auto-theme",
  "description": "Syncs Claude Code and Codex themes with macOS system appearance (light/dark) on every prompt. Bundles custom gruvbox-light / sunset-drive themes and installs them on first run.",
  "version": "1.1.2",
  "author": {
    "name": "Ivan Lutsenko",
    "email": "ivan@lutsenko.com",
    "url": "https://github.com/IvanLutsenko"
  },
  "keywords": ["theme", "dark-mode", "light-mode", "macos", "appearance", "auto"],
  "license": "MIT",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/sync-theme.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
