<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>name</key>
  <string>sunset-drive</string>
  <key>settings</key>
  <array>
    <dict>
      <key>settings</key>
      <dict>
        <key>background</key><string>#0F0F1A</string>
        <key>foreground</key><string>#EDEDFE</string>
        <key>caret</key><string>#EDEDFE</string>
        <key>selection</key><string>#202036</string>
        <key>lineHighlight</key><string>#1A1A2A</string>
        <key>invisibles</key><string>#3E3E4B</string>
      </dict>
    </dict>
    <dict>
      <key>name</key><string>Comment</string>
      <key>scope</key><string>comment, punctuation.definition.comment</string>
      <key>settings</key><dict><key>foreground</key><string>#6C6C8C</string><key>fontStyle</key><string>italic</string></dict>
    </dict>
    <dict>
      <key>name</key><string>String</string>
      <key>scope</key><string>string, string.quoted</string>
      <key>settings</key><dict><key>foreground</key><string>#00F992</string></dict>
    </dict>
    <dict>
      <key>name</key><string>Number / Constant</string>
      <key>scope</key><string>constant.numeric, constant.language, constant.character, support.constant</string>
      <key>settings</key><dict><key>foreground</key><string>#FF948B</string></dict>
    </dict>
    <dict>
      <key>name</key><string>Keyword / Storage</string>
      <key>scope</key><string>keyword, storage, storage.type, keyword.control</string>
      <key>settings</key><dict><key>foreground</key><string>#FF57FD</string></dict>
    </dict>
    <dict>
      <key>name</key><string>Operator</string>
      <key>scope</key><string>keyword.operator, punctuation.separator, punctuation.terminator</string>
      <key>settings</key><dict><key>foreground</key><string>#00FFED</string></dict>
    </dict>
    <dict>
      <key>name</key><string>Function</string>
      <key>scope</key><string>entity.name.function, support.function, meta.function-call</string>
      <key>settings</key><dict><key>foreground</key><string>#00A4FF</string></dict>
    </dict>
    <dict>
      <key>name</key><string>Type / Class</string>
      <key>scope</key><string>entity.name.type, entity.name.class, support.type, support.class</string>
      <key>settings</key><dict><key>foreground</key><string>#FFE900</string></dict>
    </dict>
    <dict>
      <key>name</key><string>Variable</string>
      <key>scope</key><string>variable, variable.parameter, variable.other</string>
      <key>settings</key><dict><key>foreground</key><string>#EDEDFE</string></dict>
    </dict>
    <dict>
      <key>name</key><string>Tag</string>
      <key>scope</key><string>entity.name.tag</string>
      <key>settings</key><dict><key>foreground</key><string>#FF0063</string></dict>
    </dict>
    <dict>
      <key>name</key><string>Attribute</string>
      <key>scope</key><string>entity.other.attribute-name</string>
      <key>settings</key><dict><key>foreground</key><string>#FFE900</string></dict>
    </dict>
    <dict>
      <key>name</key><string>Invalid</string>
      <key>scope</key><string>invalid, invalid.illegal</string>
      <key>settings</key><dict><key>foreground</key><string>#FFFFFF</string><key>background</key><string>#FF0063</string></dict>
    </dict>
  </array>
</dict>
</plist>
